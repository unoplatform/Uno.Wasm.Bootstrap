<Project>

	<!-- Property overrides -->
	<PropertyGroup>
		<WasmNativeWorkload>false</WasmNativeWorkload>
		
		<WasmGenerateAppBundleTarget>_WasmGenerateAppBundle</WasmGenerateAppBundleTarget>
		<IsBrowserWasmProject>true</IsBrowserWasmProject>
		
		<WasmGenerateAppBundle>false</WasmGenerateAppBundle>
		<CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
		
		<!-- only for non-blazor projects -->
		<WasmEmitSymbolMap Condition="'$(UsingMicrosoftNETSdkBlazorWebAssembly)' != 'true' and '$(UsingMicrosoftNETSdkWebAssembly)' != 'true' and '$(WasmEmitSymbolMap)' == '' and '$(RunAOTCompilation)' != 'true'">true</WasmEmitSymbolMap>

		<!--<WasmAppDir>$([MSBuild]::NormalizeDirectory($(MSBuildProjectDirectory), 'bin', '$(Configuration)', '$(TargetFramework)', 'AppBundle'))</WasmAppDir>-->
		<RunCommand>dotnet</RunCommand>
		<!--<_AppBundleDirForRunCommand>$(WasmAppDir)</_AppBundleDirForRunCommand>
		<_RuntimeConfigJsonPath>$([MSBuild]::NormalizePath($(WasmAppDir), '$(AssemblyName).runtimeconfig.json'))</_RuntimeConfigJsonPath>-->
	</PropertyGroup>

	<PropertyGroup>
		<_WasmRuntimePackVersion>1.0</_WasmRuntimePackVersion>
		<IsBrowserWasmProject>true</IsBrowserWasmProject>
		<EnableDefaultWasmAssembliesToBundle>true</EnableDefaultWasmAssembliesToBundle>

		<_MonoAotCrossCompilerPath>$([MSBuild]::NormalizePath($(MicrosoftNetCoreAppRuntimePackDir), 'native', 'cross', 'browser-wasm', 'mono-aot-cross'))</_MonoAotCrossCompilerPath>
		<_MonoAotCrossCompilerPath Condition="$([MSBuild]::IsOSPlatform('WINDOWS'))">$(_MonoAotCrossCompilerPath).exe</_MonoAotCrossCompilerPath>
	</PropertyGroup>

	<ItemGroup>
		<MonoAotCrossCompiler Include="$(_MonoAotCrossCompilerPath)" RuntimeIdentifier="$(TargetOS)-$(TargetArchitecture.ToLowerInvariant())" />

		<FrameworkReference Remove="Microsoft.AspNetCore.App" IsImplicitlyDefined="true" />
	</ItemGroup>

</Project>
